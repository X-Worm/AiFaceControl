# pipecat-quickstart-bouncer (AI Addicts Club) - Environment Variables
# Copy this file to .env and fill in your API key.

# Google AI (Gemini Live, speech-to-speech) - get a key at aistudio.google.com
GOOGLE_API_KEY=

# Daily (WebRTC transport, used locally and in production) - free key at
# dashboard.daily.co. Needed to create/join the call room.
DAILY_API_KEY=
# Prebuilt Gemini Live voice: Aoede, Charon, Fenrir, Kore, Puck
GEMINI_VOICE=Fenrir
# S2S model. Default (below) is verified. Uncomment the 3.1 line to try the
# newer, snappier low-latency model - confirm it's enabled on your key first.
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# --- Light rate limiting ---
# Hard cap per conversation, in seconds (main cost guardrail).
MAX_SESSION_SECONDS=180
# Soft daily guest cap ("come back tomorrow" past this).
MAX_SESSIONS_PER_DAY=50

# Club logbook via Telegram - grant_entry DMs you when a guest is let in.
# 1. Create a bot with @BotFather to get the token.
# 2. Send your bot any message, then read your chat id from:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  (look for "chat":{"id":...})
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
